{% extends "layout.njk" %}

{% set activePage="photos" %}

{% block head %} Photos {% endblock %}

{% block content %}
	<p>
		Although I am not a photographer and have never claimed to be one, I like to think that I take some pretty good pictures once and a while. With that said, it would be a shame for nobody to see them, so here they are.
	</p>
	<hr>
	<div class="row">
		<img class="asyncImage 6 col" src="{{ baseURL }}/photos/low/1.jpg" data-src="{{ baseURL }}/photos/full/1.png" alt="test picture"/>
		<div class="6 col"></div>
	</div>
	<div>
		<div class="row">
			<div class="1 col bg-info">1</div>
			<div class="3 col bg-info">3</div>
			<div class="8 col bg-info">8</div>
		</div>
	  	  <div class="12 col bg-info">12</div>
	</div>
	<script src="{{ baseURL }}/photos/imageLoader.js"></script>
{% endblock %}
